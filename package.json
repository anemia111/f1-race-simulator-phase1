{
  "name": "f1-race-simulator-phase1",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "generate:tracks": "node scripts/generate-real-track-layouts.mjs",
    "generate:support-tracks": "node scripts/generate-support-track-layouts.mjs",
    "lint": "oxlint",
    "test": "vitest run --no-file-parallelism",
    "validate:montecarlo": "vitest run --no-file-parallelism src/simulation/monteCarloAcceptance.test.ts",
    "playtest": "node scripts/run-built-playtest.mjs",
    "playtest:dev": "node scripts/broadcast-playtest.mjs",
    "benchmark": "node scripts/benchmark.mjs",
    "preview": "vite preview",
    "publish": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/publish-web-app.ps1"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "lucide-react": "^1.23.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "playwright": "^1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.10"
  }
}
